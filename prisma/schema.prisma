generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String
  name          String?
  password      String
  role          Role      @default(OWNER)
  tenantId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurantId  String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  @@unique([email, tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  timezone       String         @default("UTC")
  locale         String         @default("en-US")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customers      Customer[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  orderItems     OrderItem[]
  payments       Payment[]
  restaurants    Restaurant[]
  users          User[]
}

model Restaurant {
  id             String         @id @default(cuid())
  tenantId       String
  name           String
  slug           String
  timezone       String?
  address        String?
  city           String?
  country        String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  users          User[] 
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  currency       String   @default("INR")
  taxPercent     Decimal  @default(0)
  servicePercent Decimal  @default(0)
  phone          String?
  upiId          String?
  @@unique([tenantId, slug])
  @@index([tenantId])
}

model MenuCategory {
  id           String     @id @default(cuid())
  tenantId     String
  restaurantId String
  name         String
  description  String?
  position     Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@unique([tenantId, restaurantId, name])
  @@index([tenantId, restaurantId])
}

model MenuItem {
  id           String        @id @default(cuid())
  tenantId     String
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  sku          String?
  price        Decimal
  currency     String        @default("USD")
  type         MenuItemType  @default(FOOD)
  isAvailable  Boolean       @default(true)
  isJainAvailable Boolean @default(false)
  position     Int           @default(0)
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  category     MenuCategory? @relation(fields: [categoryId], references: [id])
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@unique([tenantId, restaurantId, sku])
  @@index([tenantId, restaurantId])
  @@index([tenantId, isAvailable])
}

model Customer {
  id         String   @id @default(cuid())
  tenantId   String
  email      String?
  phone      String?
  name       String?
  externalId String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model Order {
  id                 String      @id @default(cuid())
  tenantId           String
  restaurantId       String
  customerId         String?
  status             OrderStatus @default(PENDING)
  source             OrderSource @default(ONLINE)
  subtotal           Decimal
  tax                Decimal
  discount           Decimal     @default(0)
  total              Decimal
  currency           String      @default("USD")
  placedAt           DateTime    @default(now())
  confirmedAt        DateTime?
  fulfilledAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  notes              String?
  tableNumber        String?
  orderCode          String?
  externalId         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  customer           Customer?   @relation(fields: [customerId], references: [id])
  restaurant         Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items              OrderItem[]
  payments           Payment[]

  @@index([tenantId, restaurantId, placedAt])
  @@index([tenantId, status, placedAt])
  @@index([tenantId, customerId, placedAt])
  @@index([tenantId, orderCode])
}

model OrderItem {
  id         String    @id @default(cuid())
  tenantId   String
  orderId    String
  menuItemId String?
  name       String
  sku        String?
  unitPrice  Decimal
  quantity   Int
  totalPrice Decimal
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  orderId           String
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod
  amount            Decimal
  currency          String        @default("USD")
  provider          String?
  providerPaymentId String?       @unique
  providerChargeId  String?
  providerRefundId  String?
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum MenuItemType {
  FOOD
  DRINK
  ADDON
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum OrderSource {
  IN_STORE
  ONLINE
  DELIVERY
  KIOSK
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CARD
  CASH
  WALLET
  OTHER
}
